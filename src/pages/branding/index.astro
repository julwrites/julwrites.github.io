  <script>
    const themeToggleBtn = document.getElementById('theme-toggle');
    const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
    const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
    const brandingWrapper = document.querySelector('.branding-wrapper');

    if (themeToggleBtn && themeToggleDarkIcon && themeToggleLightIcon && brandingWrapper) {
      // Default to dark mode based on class presence
      let isDarkMode = brandingWrapper.classList.contains('dark');

      // Update icons initially
      if (isDarkMode) {
          themeToggleLightIcon.classList.remove('hidden');
      } else {
          themeToggleDarkIcon.classList.remove('hidden');
      }

      themeToggleBtn.addEventListener('click', () => {
          // Toggle wrapper class
          brandingWrapper.classList.toggle('dark');

          // Toggle icons
          themeToggleDarkIcon.classList.toggle('hidden');
          themeToggleLightIcon.classList.toggle('hidden');
      });
    }

    // Copy Functionality
    const handleCopy = async (textToCopy: string, btnElement: Element, originalContent: string) => {
        try {
            await navigator.clipboard.writeText(textToCopy);

            // Visual feedback
            const isSvgButton = btnElement.hasAttribute('data-copy-svg');
            const isCodeButton = btnElement.hasAttribute('data-copy-code');
            const isColorButton = btnElement.hasAttribute('data-copy-color');

            if (isSvgButton) {
                btnElement.textContent = 'Copied!';
            } else if (isCodeButton) {
                btnElement.innerHTML = '<svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
            } else if (isColorButton) {
                const hex = btnElement.getAttribute('data-copy-color').replace('#', '');
                btnElement.innerHTML = `${hex} <svg class="w-3 h-3 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>`;
            }

            setTimeout(() => {
                btnElement.innerHTML = originalContent;
            }, 2000);

        } catch (err) {
            console.error('Failed to copy text: ', err);
            // Handle error visually if needed
        }
    };

    // Attach listeners for SVG copy
    document.querySelectorAll('[data-copy-svg]').forEach(btn => {
        btn.addEventListener('click', () => {
            const svgId = btn.getAttribute('data-copy-svg');
            const svgElement = document.getElementById(svgId);
            if (svgElement) {
                // Get the raw HTML and format it nicely
                let svgContent = svgElement.outerHTML;

                // Optional: Cleanup the SVG string a bit if it has id or hidden classes we don't want to export
                svgContent = svgContent.replace(/class="hidden"\s*/, '');

                handleCopy(svgContent, btn, btn.innerHTML);
            }
        });
    });

    // Attach listeners for Color copy
    document.querySelectorAll('[data-copy-color]').forEach(btn => {
        btn.addEventListener('click', () => {
            const colorCode = btn.getAttribute('data-copy-color');
            handleCopy(colorCode, btn, btn.innerHTML);
        });
    });

    // Attach listeners for Code snippets
    document.querySelectorAll('[data-copy-code]').forEach(btn => {
        btn.addEventListener('click', () => {
            const codeContent = btn.getAttribute('data-copy-code');
            handleCopy(codeContent, btn, btn.innerHTML);
        });
    });
  </script>
