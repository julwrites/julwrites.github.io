---
import Layout from '../../layouts/Layout.astro';
import LogoDef from '../../components/LogoDef.astro';
import { getPath } from '../../utils/path';
---

<Layout title="tehj.io | Brand Identity Kit" description="Brand Identity Kit for tehj.io">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">

  <style is:global>
    /* Scope the body styles from the original HTML to a specific wrapper so we don't break the global Layout */
    .branding-wrapper {
        font-family: 'Outfit', sans-serif;
        --brand-bg: #f0f3f5;
        --brand-text: #3C3C3B;
        --brand-grid: rgba(200, 208, 218, 0.4);
        --brand-board-bg: rgba(248, 249, 250, 0.95);
        --brand-ruler: #cbd5e1;
        --brand-line: #9ca3af;

        background-color: var(--brand-bg);
        background-size: 20px 20px;
        color: var(--brand-text);
        padding: 2rem;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
        transition: background-color 0.3s ease, color 0.3s ease;
    }

    .branding-wrapper.dark {
        --brand-bg: #111827;
        --brand-text: #f3f4f6;
        --brand-grid: rgba(75, 85, 99, 0.4);
        --brand-board-bg: rgba(31, 41, 55, 0.95);
        --brand-ruler: #4b5563;
        --brand-line: #6b7280;
    }

    /* Reset heading colors inside the wrapper since shared.css forces h1-h6 to white */
    .branding-wrapper h1,
    .branding-wrapper h2,
    .branding-wrapper h3,
    .branding-wrapper h4,
    .branding-wrapper h5,
    .branding-wrapper h6 {
        color: var(--brand-text);
        margin: 0;
    }

    .branding-wrapper p {
        margin: 0;
    }

    .branding-board {
        background-color: var(--brand-board-bg);
        backdrop-filter: blur(10px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        position: relative;
        transition: background-color 0.3s ease;
    }

    /* Rulers overlay */
    .branding-board::before {
        content: '';
        position: absolute;
        top: 0; left: -20px; right: 0; bottom: 0;
        border-left: 1px solid var(--brand-ruler);
        background-image: repeating-linear-gradient(to bottom, transparent, transparent 9px, var(--brand-ruler) 9px, var(--brand-ruler) 10px);
        background-size: 100% 100px;
        width: 5px;
        z-index: 10;
    }
    .branding-board::after {
        content: '';
        position: absolute;
        top: -20px; left: 0; right: 0; bottom: 0;
        border-top: 1px solid var(--brand-ruler);
        background-image: repeating-linear-gradient(to right, transparent, transparent 9px, var(--brand-ruler) 9px, var(--brand-ruler) 10px);
        background-size: 100px 100%;
        height: 5px;
        z-index: 10;
    }

    .pixel-grid {
        background-size: 8px 8px;
    }

    .measure-line {
        position: absolute;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .measure-line::before, .measure-line::after {
        content: '';
        position: absolute;
        background-color: var(--brand-line);
    }
    .measure-line-x::before, .measure-line-x::after {
        width: 1px; height: 8px; top: -4px;
    }
    .measure-line-x::before { left: 0; }
    .measure-line-x::after { right: 0; }
    .measure-line-x { border-top: 1px solid var(--brand-line); }

    .measure-line-y::before, .measure-line-y::after {
        height: 1px; width: 8px; left: -4px;
    }
    .measure-line-y::before { top: 0; }
    .measure-line-y::after { bottom: 0; }
    .measure-line-y { border-left: 1px solid var(--brand-line); }
  </style>

  <div class="branding-wrapper grid-background dark">
    <!-- Reusable SVG Definition for the clean logo -->
    <LogoDef />

    <div class="branding-board max-w-7xl w-full border border-gray-300 dark:border-gray-700 p-8 md:p-12 text-sm relative">
        <!-- Dark Mode Toggle -->
        <button
          id="theme-toggle"
          class="absolute top-4 right-4 z-50 p-2 rounded-full bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200 shadow-md hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
          aria-label="Toggle Dark Mode"
        >
          <!-- Sun Icon (shows in dark mode) -->
          <svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4.22 4.22a1 1 0 011.415 1.415l-.708.707a1 1 0 01-1.414-1.414l.707-.708zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zm-4.22-4.22a1 1 0 01-1.415-1.415l.708-.707a1 1 0 011.414 1.414l-.707.708zM5 9a1 1 0 100 2H4a1 1 0 100-2h1zM8 10a2 2 0 100-4 2 2 0 000 4z"></path>
            <path d="M10 16a6 6 0 100-12 6 6 0 000 12z"></path>
          </svg>
          <!-- Moon Icon (shows in light mode) -->
          <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
          </svg>
        </button>

        <!-- Top Half -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

            <!-- LEFT COLUMN -->
            <div class="space-y-12">

                <!-- Primary Logo -->
                <div class="relative">
                    <h2 class="text-xs font-semibold tracking-wider text-gray-600 dark:text-gray-400 mb-8 absolute -top-4 -left-2">PRIMARY LOGO</h2>

                    <div class="absolute top-0 right-0 flex gap-2 z-10">
                        <button class="text-[10px] px-2 py-1 border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" data-copy-svg="clean-logo" data-umami-event="branding-copy-svg" data-umami-event-svg="clean-logo">Copy SVG</button>
                        <a href={getPath('/assets/branding/logo/vector/default.svg')} download class="text-[10px] px-2 py-1 border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors flex items-center gap-1" data-umami-event="branding-download-asset" data-umami-event-asset="default.svg"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg> SVG</a>
                        <a href={getPath('/assets/branding/logo/default.png')} download class="text-[10px] px-2 py-1 border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors flex items-center gap-1" data-umami-event="branding-download-asset" data-umami-event-asset="default.png"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg> PNG</a>
                    </div>

                    <div class="flex flex-col items-center justify-center pt-8">
                        <!-- SVG with Vector Nodes (Illustrator Style) -->
                        <div class="relative w-40 h-40 mb-4 text-[#3C3C3B] dark:text-[#f3f4f6]">
                            <svg viewBox="0 0 100 100" class="w-full h-full overflow-visible">
                                <use href="#clean-logo" />

                                <!-- Vector Node Overlays to match image -->
                                <g fill="var(--brand-board-bg)" stroke="currentColor" stroke-width="0.8">
                                    <circle cx="50" cy="10" r="1.5" />
                                    <circle cx="50" cy="35" r="1.5" />
                                    <circle cx="50" cy="58" r="1.5" />
                                    <circle cx="25" cy="35" r="1.5" />
                                    <circle cx="75" cy="35" r="1.5" />
                                    <circle cx="28" cy="65" r="1.5" />
                                    <circle cx="50" cy="87" r="1.5" /> <!-- Curve control point estimate -->
                                    <circle cx="72" cy="65" r="1.5" />
                                    <circle cx="72" cy="45" r="1.5" />
                                    <circle cx="44" cy="60" r="1.5" />
                                    <circle cx="56" cy="60" r="1.5" />
                                    <circle cx="50" cy="78" r="1.5" />
                                </g>
                                <!-- Control handles -->
                                <line x1="28" y1="65" x2="28" y2="55" stroke="currentColor" stroke-width="0.5" />
                                <circle cx="28" cy="55" r="1" fill="currentColor" />
                                <line x1="72" y1="45" x2="72" y2="35" stroke="currentColor" stroke-width="0.5" />
                                <circle cx="72" cy="35" r="1" fill="currentColor" />

                                <!-- Mint circle nodes -->
                                <circle cx="72" cy="16" r="1" fill="none" stroke="#3AFBC0" stroke-width="0.5" />
                                <circle cx="72" cy="28" r="1" fill="none" stroke="#3AFBC0" stroke-width="0.5" />
                                <circle cx="66" cy="22" r="1" fill="none" stroke="#3AFBC0" stroke-width="0.5" />
                                <circle cx="78" cy="22" r="1" fill="none" stroke="#3AFBC0" stroke-width="0.5" />
                                <path d="M 72 16 A 6 6 0 0 1 78 22 A 6 6 0 0 1 72 28 A 6 6 0 0 1 66 22 A 6 6 0 0 1 72 16" fill="none" stroke="#3AFBC0" stroke-width="0.5" />
                            </svg>
                        </div>
                        <h1 class="text-6xl font-bold tracking-tight mb-2">tehj.io</h1>
                        <p class="text-xl font-light tracking-widest text-gray-700 dark:text-gray-300">Create . Bless . Truth</p>
                    </div>
                </div>

                <div class="h-px bg-gray-300 dark:bg-gray-700 w-full my-8"></div>

                <!-- Logotype Only -->
                <div class="relative">
                    <h2 class="text-xs font-semibold tracking-wider text-gray-600 dark:text-gray-400 mb-8 absolute -top-4 -left-2">LOGOTYPE ONLY</h2>
                    <div class="absolute top-0 right-0 flex gap-2 z-10">
                        <a href={getPath('/assets/branding/logo/vector/isolated-layout.svg')} download class="text-[10px] px-2 py-1 border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors flex items-center gap-1" data-umami-event="branding-download-asset" data-umami-event-asset="isolated-layout.svg"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg> SVG</a>
                    </div>
                    <div class="flex items-center justify-center gap-12 pt-8">
                        <div class="text-center">
                            <h1 class="text-6xl font-bold tracking-tight mb-2">tehj.io</h1>
                            <p class="text-xl font-light tracking-widest text-gray-700 dark:text-gray-300">Create . Bless . Truth</p>
                        </div>
                        <div class="text-[10px] text-gray-500 dark:text-gray-400 leading-relaxed border-l border-gray-300 dark:border-gray-600 pl-4">
                            <p class="font-semibold text-gray-700 dark:text-gray-300">Typeface: Geometric Sans-Serif Regular/Light</p>
                            <p>Size: 18pt/12pt</p>
                            <p>Leading: 24pt</p>
                        </div>
                    </div>
                </div>

            </div>

            <!-- RIGHT COLUMN -->
            <div class="space-y-12 border-l border-gray-300 dark:border-gray-700 pl-12 relative">

                <!-- Brand Color Palette -->
                <div class="relative">
                    <h2 class="text-xs font-semibold tracking-wider text-gray-600 dark:text-gray-400 mb-6">BRAND COLOR PALETTE</h2>
                    <div class="flex gap-12">
                        <!-- Color 1 -->
                        <div class="flex gap-4">
                            <div class="w-20 h-20 bg-[#3C3C3B] border border-gray-200 dark:border-gray-700"></div>
                            <div class="text-[10px] leading-tight flex flex-col justify-between py-1">
                                <div>
                                    <p class="text-sm font-semibold mb-1">Graphite Gray <span class="font-mono text-[8px] bg-gray-200 dark:bg-gray-700 px-1 py-0.5 rounded ml-1 font-normal">--border-color</span></p>
                                    <p><span class="w-8 inline-block">HEX</span> 3C3C3B</p>
                                    <p><span class="w-8 inline-block">RGB</span> 60, 60, 59</p>
                                    <p><span class="w-8 inline-block">CMYK</span> 67, 58, 59, 41</p>
                                    <p><span class="w-8 inline-block">HSL</span> 60, 1, 23</p>
                                </div>
                                <button class="font-bold hover:text-gray-500 transition-colors flex items-center gap-1" data-copy-color="#3C3C3B" data-umami-event="branding-copy-color" data-umami-event-color="#3C3C3B">3C3C3B <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path></svg></button>
                            </div>
                        </div>
                        <!-- Color 2 -->
                        <div class="flex gap-4">
                            <div class="w-20 h-20 bg-[#3AFBC0] border border-gray-200 dark:border-gray-700"></div>
                            <div class="text-[10px] leading-tight flex flex-col justify-between py-1">
                                <div>
                                    <p class="text-sm font-semibold mb-1">Active Mint</p>
                                    <p><span class="w-8 inline-block">HEX</span> 3AFBC0</p>
                                    <p><span class="w-8 inline-block">RGB</span> 58, 251, 192</p>
                                    <p><span class="w-8 inline-block">CMYK</span> 56, 0, 38, 0</p>
                                    <p><span class="w-8 inline-block">HSL</span> 161, 96, 60</p>
                                </div>
                                <button class="font-bold hover:text-gray-500 transition-colors flex items-center gap-1" data-copy-color="#3AFBC0" data-umami-event="branding-copy-color" data-umami-event-color="#3AFBC0">3AFBC0 <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path></svg></button>
                            </div>
                        </div>
                    </div>

                    <div class="flex gap-12 mt-6">
                        <!-- Color 3 -->
                        <div class="flex gap-4">
                            <div class="w-20 h-20 bg-[#00E5FF] border border-gray-200 dark:border-gray-700"></div>
                            <div class="text-[10px] leading-tight flex flex-col justify-between py-1">
                                <div>
                                    <p class="text-sm font-semibold mb-1">Neon Cyan</p>
                                    <p><span class="w-8 inline-block">HEX</span> 00E5FF</p>
                                    <p><span class="w-8 inline-block">RGB</span> 0, 229, 255</p>
                                    <p><span class="w-8 inline-block">HSL</span> 186, 100, 50</p>
                                </div>
                                <button class="font-bold hover:text-gray-500 transition-colors flex items-center gap-1" data-copy-color="#00E5FF" data-umami-event="branding-copy-color" data-umami-event-color="#00E5FF">00E5FF <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path></svg></button>
                            </div>
                        </div>
                        <!-- Color 4 -->
                        <div class="flex gap-4">
                            <div class="w-20 h-20 bg-[#222C3C] border border-gray-200 dark:border-gray-700"></div>
                            <div class="text-[10px] leading-tight flex flex-col justify-between py-1">
                                <div>
                                    <p class="text-sm font-semibold mb-1">Dark Blue <span class="font-mono text-[8px] bg-gray-200 dark:bg-gray-700 px-1 py-0.5 rounded ml-1 font-normal">--background-color</span></p>
                                    <p><span class="w-8 inline-block">HEX</span> 222C3C</p>
                                    <p><span class="w-8 inline-block">RGB</span> 34, 44, 60</p>
                                    <p><span class="w-8 inline-block">HSL</span> 217, 28, 18</p>
                                </div>
                                <button class="font-bold hover:text-gray-500 transition-colors flex items-center gap-1" data-copy-color="#222C3C" data-umami-event="branding-copy-color" data-umami-event-color="#222C3C">222C3C <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path></svg></button>
                            </div>
                        </div>
                    </div>

                    <div class="flex gap-12 mt-6">
                        <!-- Color 5 -->
                        <div class="flex gap-4">
                            <div class="w-20 h-20 bg-[#3273DC] border border-gray-200 dark:border-gray-700"></div>
                            <div class="text-[10px] leading-tight flex flex-col justify-between py-1">
                                <div>
                                    <p class="text-sm font-semibold mb-1">Accent Blue <span class="font-mono text-[8px] bg-gray-200 dark:bg-gray-700 px-1 py-0.5 rounded ml-1 font-normal">--accent-color</span></p>
                                    <p><span class="w-8 inline-block">HEX</span> 3273DC</p>
                                    <p><span class="w-8 inline-block">RGB</span> 50, 115, 220</p>
                                    <p><span class="w-8 inline-block">HSL</span> 217, 71, 53</p>
                                </div>
                                <button class="font-bold hover:text-gray-500 transition-colors flex items-center gap-1" data-copy-color="#3273DC" data-umami-event="branding-copy-color" data-umami-event-color="#3273DC">3273DC <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path></svg></button>
                            </div>
                        </div>
                        <!-- Color 6 -->
                        <div class="flex gap-4">
                            <div class="w-20 h-20 bg-[#2A3547] border border-gray-200 dark:border-gray-700"></div>
                            <div class="text-[10px] leading-tight flex flex-col justify-between py-1">
                                <div>
                                    <p class="text-sm font-semibold mb-1">Card Bg <span class="font-mono text-[8px] bg-gray-200 dark:bg-gray-700 px-1 py-0.5 rounded ml-1 font-normal">--card-background</span></p>
                                    <p><span class="w-8 inline-block">HEX</span> 2A3547</p>
                                    <p><span class="w-8 inline-block">RGB</span> 42, 53, 71</p>
                                    <p><span class="w-8 inline-block">HSL</span> 217, 26, 22</p>
                                </div>
                                <button class="font-bold hover:text-gray-500 transition-colors flex items-center gap-1" data-copy-color="#2A3547" data-umami-event="branding-copy-color" data-umami-event-color="#2A3547">2A3547 <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path></svg></button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="h-px bg-gray-300 dark:bg-gray-700 w-full my-8"></div>

                <!-- Favicon / Icon -->
                <div class="relative">
                    <h2 class="text-xs font-semibold tracking-wider text-gray-600 dark:text-gray-400 mb-8">FAVICON / ICON</h2>
                    <div class="absolute top-0 right-0 flex gap-2 z-10">
                        <a href={getPath('/assets/branding/logo/vector/favicon.svg')} download class="text-[10px] px-2 py-1 border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors flex items-center gap-1" data-umami-event="branding-download-asset" data-umami-event-asset="favicon.svg"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg> SVG</a>
                    </div>
                    <div class="flex items-end gap-8 relative mt-12">
                        <!-- 16x16 -->
                        <div class="flex flex-col items-center gap-2">
                            <svg viewBox="0 0 100 100" class="w-4 h-4 text-[#3C3C3B] dark:text-[#f3f4f6]"><use href="#clean-logo" /></svg>
                            <p class="text-[10px] text-gray-500 dark:text-gray-400">16x16</p>
                        </div>
                        <!-- 32x32 -->
                        <div class="flex flex-col items-center gap-2">
                            <svg viewBox="0 0 100 100" class="w-8 h-8 text-[#3C3C3B] dark:text-[#f3f4f6]"><use href="#clean-logo" /></svg>
                            <p class="text-[10px] text-gray-500 dark:text-gray-400">32x32</p>
                        </div>
                        <!-- 64x64 -->
                        <div class="flex flex-col items-center gap-2">
                            <svg viewBox="0 0 100 100" class="w-16 h-16 text-[#3C3C3B] dark:text-[#f3f4f6]"><use href="#clean-logo" /></svg>
                            <p class="text-[10px] text-gray-500 dark:text-gray-400">64x64</p>
                        </div>

