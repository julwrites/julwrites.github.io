---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getPath } from '../../utils/path';
import { formatDate } from '../../utils/post';

import type { CollectionEntry } from 'astro:content';

import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={`${post.data.title} | tehj.io`}>
  <main class="max-w-[800px] mx-auto px-4 sm:px-0">
    <article class="mb-16">
      <h1>{post.data.title}</h1>
      <div class="date">
        <time datetime={post.data.pubDate.toISOString()}>
          {formatDate(post.data.pubDate)}
        </time>
        {post.data.updatedDate && (
          <div class="updated">
            Last updated on <time datetime={post.data.updatedDate.toISOString()}>
              {formatDate(post.data.updatedDate)}
            </time>
          </div>
        )}
      </div>
      {post.data.heroImage && (
        <img 
          src={post.data.heroImage.startsWith('/') ? getPath(post.data.heroImage) : post.data.heroImage}
          alt={`Hero image for ${post.data.title}`}
          class="hero-image"
        />
      )}
      <div class="content prose dark:prose-invert max-w-none">
        <Content />
      </div>
    </article>
  </main>
</Layout>

<style>
  h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .date {
    margin-bottom: 2rem;
    color: var(--disabled-font-color);
  }

  .updated {
    margin-top: 0.5rem;
    font-style: italic;
  }

  .hero-image {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: 2rem;
  }

  .content {
    line-height: 1.6;
  }
</style>
