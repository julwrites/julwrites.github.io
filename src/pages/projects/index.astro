---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { sortPostsByDate, formatDate } from '../../utils/post';
import { getPath } from '../../utils/path';

// Get all project posts sorted by date
const projects = await getCollection('projects');
const sortedProjects = sortPostsByDate(projects);
---

<Layout title="Projects | tehj.io">
  <main class="flex flex-col gap-[var(--content-spacing)] max-w-[800px] w-full mx-auto px-4 sm:px-0">
    <div class="flex flex-row justify-center items-center gap-4 mb-8">
      <h1 class="text-[40px] font-medium m-0">Projects</h1>
      <a href={getPath('/projects/rss.xml')} target="_blank" rel="noopener noreferrer" title="RSS Feed" data-umami-event="rss-feed-click" data-umami-event-type="projects">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-rss"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
      </a>
    </div>
    <ul class="project-list">
      {sortedProjects.map((project) => (
        <li class="project-item">
          <a href={getPath(`/projects/${project.slug}/`)} data-umami-event="project-post-click" data-umami-event-project={project.data.title}>
            <h2 class="project-title">{project.data.title}</h2>
            <p class="project-date">{formatDate(project.data.pubDate)}</p>
            <p class="project-description">{project.data.description}</p>
            <span class="btn-secondary px-4 py-2 mt-4 rounded-md inline-block hover:brightness-110 transition-colors text-sm w-fit">Read More</span>
          </a>
        </li>
      ))}
    </ul>
  </main>
</Layout>

<style>
  .project-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .project-item {
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 2rem;
  }

  .project-item a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .project-title {
    font-size: 24px;
    margin: 0 0 0.5rem 0;
  }

  .project-date {
    font-size: 14px;
    color: var(--disabled-font-color);
    margin: 0 0 0.5rem 0;
  }

  .project-description {
    margin: 0;
    line-height: 1.5;
  }
</style>
