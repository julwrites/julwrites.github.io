---
import Layout from '../../layouts/Layout.astro';                                
                                                                                
const labs = [
  {
    name: "Fasting Management",
    path: "/labs/fasting-management/index.html",
    description: "Visualization of the effect of fasting on health "
  },
  {
    name: "Temperament Quiz",
    path: "/labs/temperament-quiz/index.html",
    description: "Discover your unique personality blend"
  },
  {
    name: "Mortgage Calculator",
    path: "/labs/mortgage-calculator/index.html",
    description: "Calculate mortgage payments with extra payment options"
  },
  {
    name: "Singapore Tax Calculator",
    path: "/labs/sg-tax-calculator/index.html",
    description: "Calculate Singapore income tax with deductions"
  },
  {
    name: "Cortisol Management",
    path: "/labs/cortisol-management/index.html",
    description: "Visualization of the effect of lifestyle on cortisol"
  }
];                                                                              
---                                                                             
                                                                                
<Layout title="Labs | tehj.io">                                                 
  <main class="max-w-3xl mx-auto px-4 py-8">                                    
    <h1 class="text-3xl font-bold mb-6">Labs</h1>                               
    <p class="mb-8 text-[var(--disabled-font-color)]">
      Interactive tools and experiments                                         
    </p>                                                                        
                                                                                
    <div class="grid gap-6 md:grid-cols-2">                                     
      {labs.map(lab => (                                                        
        <a                                                                      
          href={lab.path}                                                       
          class="block p-6 border border-[var(--border-color)] rounded-lg hover:bg-[var(--hover-bg)] transition-colors group"
          data-umami-event="lab-click"
          data-umami-event-lab={lab.name}
        >                                                                       
          <h2 class="text-xl font-medium text-[var(--accent-color)] mb-2">
            {lab.name}                                                          
          </h2>                                                                 
          <p class="text-[var(--font-color)] opacity-80">
            {lab.description}                                                   
          </p>                                                                  
          <div class="mt-4 text-sm text-[var(--accent-color)] opacity-90">
            Try it out →                                                        
          </div>                                                                
        </a>                                                                    
      ))}                                                                       
    </div>                                                                      
  </main>                                                                       
</Layout>                                                                       
