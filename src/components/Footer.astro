---
---

<footer>
  <div class="links-container flex justify-center w-full mb-6">
    <div class="links-section flex flex-col items-center p-4 w-full max-w-[500px] bg-[var(--card-background)] rounded-[var(--border-radius)] shadow-md gap-[var(--footer-spacing)]">
      <p>Connect With Me</p>
      <div class="icons flex flex-wrap justify-center gap-[var(--footer-spacing)] w-full">
        <a href="https://github.com/julwrites/julwrites.github.io/raw/main/public/assets/resume/Resume_Julian_Teh.pdf" target="_blank" title="Resume">
          <img src="/assets/images/dark/resume.png" alt="Resume" />
          <span>Resume</span>
        </a>
        <a href="https://linkedin.com/in/julwrites" target="_blank" title="LinkedIn">
          <img src="/assets/images/dark/linkedin.png" alt="LinkedIn" />
          <span>LinkedIn</span>
        </a>
        <a href="mailto:contact@tehj.io" target="_blank" title="Email">
          <img src="/assets/images/dark/email.png" alt="Email" />
          <span>Email</span>
        </a>
      </div>
    </div>
  </div>
  <p>&copy; {new Date().getFullYear()} Julian Teh. All rights reserved.</p>
</footer>

<style>
  footer {
    margin-top: 2em;
    padding-top: 1em;
    border-top: 1px solid var(--disabled-font-color);
    text-align: center;
  }
  
  p {
    color: var(--disabled-font-color);
    font-size: 0.9em;
    margin-top: 1em;
  }
  
  .icons a {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 10px;
    border-radius: var(--border-radius);
    transition: background-color 0.2s ease;
    min-width: 80px;
  }
  
  .icons a:hover {
    background-color: rgba(255, 255, 255, 0.1);
    text-decoration: none;
  }

  .icons img {
    width: 33px;
    height: 33px;
    transition: transform 0.2s ease;
  }
  
  .icons a:hover img {
    transform: scale(1.1);
  }
  
  .icons span {
    font-size: 0.9rem;
    color: var(--font-color);
  }
</style>
