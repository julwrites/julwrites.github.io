---
import { getPath, isActivePath } from '../utils/path';
---

<header>
  <div class="header-content flex flex-col md:flex-row gap-2 md:gap-0 justify-between items-center">
    <a href={getPath('/')} class="flex items-center gap-3 logo-link" data-umami-event="nav-click" data-umami-event-nav="logo-home">
      <svg viewBox="0 0 100 100" class="w-8 h-8 text-[#ffffff]"><use href="#clean-logo" /></svg>
      <h2 class="text-xl font-bold tracking-tight">tehj.io</h2>
    </a>
    <nav class="flex justify-center md:justify-end m-0">
      <a href={getPath('/')} class={isActivePath(Astro.url.pathname, '/', true) ? 'active' : ''} data-umami-event="nav-click" data-umami-event-nav="home">Home</a>
      <a href={getPath('/projects')} class={isActivePath(Astro.url.pathname, '/projects') ? 'active' : ''} data-umami-event="nav-click" data-umami-event-nav="projects">Projects</a>
      <a href={getPath('/blog')} class={isActivePath(Astro.url.pathname, '/blog') ? 'active' : ''} data-umami-event="nav-click" data-umami-event-nav="blog">Blog</a>
      <a href="https://github.com/julwrites" target="_blank" rel="noopener noreferrer" data-umami-event="nav-click" data-umami-event-nav="github">GitHub</a>
    </nav>
  </div>
</header>

<style>
  header {
    margin-bottom: 2em;
  }
  
  h2 {
    margin: 0;
  }

  .logo-link {
    text-decoration: none;
    color: var(--font-color);
  }

  .logo-link:hover {
    text-decoration: none;
  }
</style>
