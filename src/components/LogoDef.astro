---
// SVG Definition for the clean logo
---
<svg width="0" height="0" class="hidden">
    <defs>
        <g id="clean-logo">
            <!-- Vertical Stem -->
            <line x1="50" y1="10" x2="50" y2="58" stroke="currentColor" stroke-width="6" stroke-linecap="round" />
            <!-- Horizontal Bar -->
            <line x1="25" y1="35" x2="75" y2="35" stroke="currentColor" stroke-width="6" stroke-linecap="round" />
            <!-- U-Shape Bottom (Modified into a 'j') -->
            <!-- The right side goes up to the middle of the dot (cy=22, instead of 42) -->
            <!-- We'll keep the left side standard, but the right side path will go up to cy=45 to maintain equal spacing -->
            <path d="M 28 65 A 22 22 0 0 0 72 65 L 72 45" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
            <!-- Pen Nib -->
            <path d="M 44 60 L 56 60 L 50 78 Z" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
            <circle cx="50" cy="65" r="1.5" fill="var(--brand-board-bg)" />
            <line x1="50" y1="67" x2="50" y2="76" stroke="var(--brand-board-bg)" stroke-width="1" />
            <!-- Active Mint Dot, moved above the right arm of the cross -->
            <circle cx="72" cy="22" r="6" fill="#3AFBC0" />
        </g>
    </defs>
</svg>